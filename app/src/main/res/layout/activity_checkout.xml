<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CheckoutActivity">

    <!-- Progress indicator while fetching checkout session -->
    <ProgressBar
        android:id="@+id/checkout_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- WebView for Stripe Checkout, hidden initially -->
    <WebView
        android:id="@+id/checkout_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Container for item details (Removed for direct checkout) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/details_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <!-- Kept minimal views to avoid code crashes if referenced -->
        <TextView android:id="@+id/item_name_text" android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/item_price_text" android:layout_width="0dp" android:layout_height="0dp" />
        <Button android:id="@+id/pay_button" android:layout_width="0dp" android:layout_height="0dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>